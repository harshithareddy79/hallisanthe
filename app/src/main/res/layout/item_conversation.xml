<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:background="@color/white"
    android:foreground="?attr/selectableItemBackground">

    <!-- Avatar circle -->
    <TextView
        android:id="@+id/convAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:background="@drawable/circle_background"
        android:layout_marginEnd="12dp" />

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/convName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seller Name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/convProduct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Re: Product"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/convLastMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last message here"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Right side: time + badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/convTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/convUnreadBadge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:text="1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/circle_background"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
